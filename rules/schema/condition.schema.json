{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "condition.schema.json",
  "title": "Condition node",
  "oneOf": [
    {
      "type": "object",
      "title": "Always (unconditional match/no-match, used for baseline rules)",
      "required": ["always"],
      "properties": { "always": { "type": "boolean" } },
      "additionalProperties": false
    },
    {
      "type": "object",
      "title": "AND group",
      "required": ["all"],
      "properties": {
        "all": { "type": "array", "minItems": 1, "items": { "$ref": "condition.schema.json" } }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "title": "OR group",
      "required": ["any"],
      "properties": {
        "any": { "type": "array", "minItems": 1, "items": { "$ref": "condition.schema.json" } }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "title": "NOT",
      "required": ["not"],
      "properties": { "not": { "$ref": "condition.schema.json" } },
      "additionalProperties": false
    },
    {
      "type": "object",
      "title": "Leaf comparison",
      "required": ["field", "op"],
      "properties": {
        "field": {
          "type": "string",
          "description": "Dot path into the evaluation context, e.g. 'client.country' or 'loan.amount'."
        },
        "op": {
          "type": "string",
          "enum": [
            "eq", "neq", "gt", "gte", "lt", "lte",
            "in", "not_in", "contains", "not_contains",
            "exists", "not_exists", "is_empty", "is_not_empty",
            "regex", "between"
          ]
        },
        "value": {
          "description": "Comparison value. Omit for exists/not_exists/is_empty/is_not_empty."
        }
      },
      "additionalProperties": false
    }
  ]
}
